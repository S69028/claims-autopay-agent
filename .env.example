# Copy this file to `.env` and fill in the keys you need.
# Keep secrets out of version control.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GITHUB_TOKEN=
GH_TOKEN=

# Monthly report delivery (send-only account)
REPORT_SMTP_PROVIDER=gmail
REPORT_SMTP_HOST=smtp.gmail.com
REPORT_SMTP_PORT=465
REPORT_SMTP_USE_SSL=true
REPORT_SMTP_USERNAME=
REPORT_SMTP_PASSWORD=
REPORT_SMTP_FROM=
REPORT_SMTP_DISPLAY_NAME=자동심사 현황분석 Agent
REPORT_RECIPIENTS_CSV=data/private/report_subscription_accounts.csv
REPORT_DEFAULT_SUBJECT_PREFIX=[자동심사 현황분석]
